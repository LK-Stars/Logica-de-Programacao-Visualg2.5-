algoritmo "semnome"
// Função :
// Autor :
// Data : 18/04/2026
// Seção de Declarações 
var
tab , c : inteiro

inicio
escreval ("Informe o valor da tabauada desejada")
leia (tab)

c <- 1

enquanto c <= 10 faca
escreval (tab , " x " , c , " = " , ( tab * c))

c <- c + 1

fimenquanto
// Seção de Comandos 
fimalgoritmo
