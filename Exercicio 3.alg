algoritmo "semnome"
// Funçăo :
// Autor :
// Data : 11/03/2026
// Seçăo de Declaraçőes

var
a , b : inteiro
c : real

inicio
escreval  ("Digite o valor de a")
leia (a)

escreval  ("Digite o valor de b")
leia (b)

c  <-  a  +  b
escreval ("Digite o valor de ŕ  " , c)

c  <-  a  *  b
escreval ("Digite o valor de ŕ  " , c)

c  <-  a  /  b
escreval ("Digite o valor de ŕ  " , c)

c  <-  a  -  b
escreval ("Digite o valor de ŕ  " , c)
// Seçăo de Comandos
Fimalgoritmo
