algoritmo "semnome"
// Função :
// Autor :
// Data : 17/04/2026
// Seção de Declarações 
var
nm , nmp , nmd , c , a , b : inteiro

inicio
c <- 1

enquanto c < 100 faca
se c % 2 = 0 entao
escreval (c , " par")

senao
escreval (c , " impar")

fimse

c <- c + 1

fimenquanto
// Seção de Comandos 
fimalgoritmo
