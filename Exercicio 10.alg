algoritmo "semnome"
// Funçăo :
// Autor :
// Data : 17/04/2026
// Seçăo de Declaraçőes 
var
valor , valor2 , c : inteiro

inicio
valor <- randi (100)

enquanto valor <> valor2 faca
escreval ("Tente adivinhar o número secreto entre 0 e 100")
leia (valor2)

se valor2 > valor entao
escreval ("O número é menor do que o digitado")

senao
se valor2 < valor entao
escreval ("O número é maior do que o digitado")

senao
escreval ("Parabéns! Vocę acertou!")

fimse
fimse

c <- c + 1

fimenquanto
// Seçăo de Comandos
fimalgoritmo
