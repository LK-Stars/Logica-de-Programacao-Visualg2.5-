algoritmo "semnome"
// Função :
// Autor :
// Data : 17/04/2026
// Seção de Declarações 
var
idade : inteiro

inicio
escreval ("Informe a sua idade")
leia (idade)

se idade >= 18 entao
escreval ("Liga luz verde: Liberado")

senao
se idade < 18 entao
escreval ("Liga luz vermelha: Bloqueado")

fimse
fimse
// Seção de Comandos 
fimalgoritmo


